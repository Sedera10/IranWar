# Activer le moteur de réécriture
RewriteEngine On

# Définir le répertoire de base
RewriteBase /

# ====================================
# ETAPE 4: OPTIMISATION SERVEUR
# ====================================

# --- HTTPS (décommenter en production avec certificat SSL) ---
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Supprimer le www (uniformisation URL) ---
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# --- HSTS (HTTP Strict Transport Security) - décommenter en production ---
# <IfModule mod_headers.c>
#     Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
# </IfModule>

# Empêcher l'accès aux fichiers sensibles
RewriteRule ^config/ - [F,L]
RewriteRule ^core/ - [F,L]
RewriteRule ^app/ - [F,L]

# Autoriser les fichiers statiques
RewriteCond %{REQUEST_URI} ^/public/
RewriteRule ^public/(.*)$ public/$1 [L]

# ====================================
# ETAPE 5: URL REWRITING SEO
# ====================================
# Format URL: /categorie/article/YYYY/MM/DD/titre-de-l-article_ID.html
# Exemple: /politique/article/2026/03/31/iran-tensions-nucleaires_123.html

# --- Article avec catégorie, date et slug ---
# URL: /politique/article/2026/03/31/titre-article_123.html
# Capture: $1=categorie, $2=annee, $3=mois, $4=jour, $5=slug, $6=id
RewriteRule ^([a-z0-9-]+)/article/([0-9]{4})/([0-9]{2})/([0-9]{2})/([a-z0-9-]+)_([0-9]+)\.html$ index.php?url=articles/show/$6 [L,QSA]

# --- Article simplifié avec slug et ID ---
# URL: /article/titre-article_123.html
# Capture: $1=slug, $2=id
RewriteRule ^article/([a-z0-9-]+)_([0-9]+)\.html$ index.php?url=articles/show/$2 [L,QSA]

# --- Catégorie avec slug ---
# URL: /categorie/politique_1.html
# Capture: $1=slug, $2=id
RewriteRule ^categorie/([a-z0-9-]+)_([0-9]+)\.html$ index.php?url=articles/category/$2 [L,QSA]

# --- Page actualités ---
# URL: /actualites.html
RewriteRule ^actualites\.html$ index.php?url=articles/index [L,QSA]

# --- Recherche ---
# URL: /recherche.html?q=keyword
RewriteRule ^recherche\.html$ index.php?url=articles/search [L,QSA]

# --- Page d'accueil ---
# URL: /accueil.html
RewriteRule ^accueil\.html$ index.php?url=home/index [L,QSA]

# --- Pages statiques ---
# URL: /a-propos.html
RewriteRule ^a-propos\.html$ index.php?url=home/about [L,QSA]

# URL: /contact.html
RewriteRule ^contact\.html$ index.php?url=home/contact [L,QSA]

# --- Fallback: Rediriger toutes les autres requêtes vers index.php ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# ====================================
# ETAPE 1: OPTIMISATION IMAGES
# ====================================
# Types MIME pour images modernes
<IfModule mod_mime.c>
    AddType image/webp .webp
    AddType image/avif .avif
    AddType image/svg+xml .svg
</IfModule>

# ====================================
# ETAPE 2: OPTIMISATION CSS
# ====================================
# Types MIME CSS/JS
<IfModule mod_mime.c>
    AddType text/css .css
    AddType application/javascript .js
</IfModule>

# Compression GZIP (CSS, JS, HTML, PHP)
<IfModule mod_deflate.c>
    # HTML et PHP
    AddOutputFilterByType DEFLATE text/html text/plain text/xml application/xhtml+xml
    # CSS
    AddOutputFilterByType DEFLATE text/css
    # JavaScript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
    # JSON
    AddOutputFilterByType DEFLATE application/json application/ld+json
    # SVG et XML
    AddOutputFilterByType DEFLATE image/svg+xml application/xml
    # Fonts
    AddOutputFilterByType DEFLATE application/font-woff application/font-woff2
    
    # Exclure les fichiers déjà compressés
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif|zip|gz|bz2)$ no-gzip
</IfModule>

# ====================================
# ETAPE 3: CHARGEMENT ASYNCHRONE
# ====================================
# Keep-Alive pour connexions persistantes
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# ====================================
# CACHE SERVEUR (mod_expires)
# ====================================
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Cache par défaut (1 mois)
    ExpiresDefault "access plus 1 month"
    
    # HTML - pas de cache (contenu dynamique)
    ExpiresByType text/html "access plus 0 seconds"
    
    # Images (1 an)
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS et JavaScript (1 an)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # Fonts (1 an)
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # JSON/XML (pas de cache)
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
</IfModule>

# ====================================
# CACHE NAVIGATEUR (mod_headers)
# ====================================
<IfModule mod_headers.c>
    # Cache long pour ressources statiques (1 an)
    <FilesMatch "\.(ico|pdf|jpg|jpeg|png|gif|webp|avif|svg|woff|woff2)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    
    # Cache pour CSS/JS minifiés (1 an)
    <FilesMatch "\.min\.(css|js)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    
    # Cache court pour CSS/JS non-minifiés (1 semaine)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=604800, public"
    </FilesMatch>
    
    # Pas de cache pour HTML/PHP (contenu dynamique)
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# ====================================
# ETags (validation cache)
# ====================================
<IfModule mod_headers.c>
    # Désactiver ETags pour éviter les problèmes de serveurs multiples
    # Utiliser Cache-Control à la place
    Header unset ETag
</IfModule>
FileETag None

# ====================================
# SECURITE
# ====================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # Content Security Policy - inclut TinyMCE CDN
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tiny.cloud; style-src 'self' 'unsafe-inline' https://cdn.tiny.cloud; img-src 'self' data: https: blob:; font-src 'self' https://cdn.tiny.cloud; connect-src 'self' https://cdn.tiny.cloud; frame-src 'self' blob:"
</IfModule>

# Empêcher le listage des répertoires
Options -Indexes

# Définir le charset par défaut
AddDefaultCharset UTF-8

# Redirection erreur
ErrorDocument 404 /404.php
